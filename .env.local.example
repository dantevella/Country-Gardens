# Endpoint for inquiry + donation form submissions (Formspree)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/maqlgggp

# Disable Next.js outbound calls at startup (telemetry + update check).
# Recommended on restricted networks to avoid dev-server hangs.
NEXT_TELEMETRY_DISABLED=1
NO_UPDATE_NOTIFIER=1
